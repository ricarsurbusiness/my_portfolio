---
import type { Project } from "../types/portfolio";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

// Obtener el base path para GitHub Pages
const base = import.meta.env.BASE_URL;

// Función helper para añadir el base path a las URLs de imágenes
const getImageUrl = (url: string) => {
  if (!url || url.startsWith("http")) return url;
  return url.startsWith("/") ? `${base}${url.slice(1)}` : `${base}${url}`;
};

type MediaItem = {
  type: "image" | "video";
  url: string;
  alt: string;
};

// Convertir projects a JSON string para pasar al script
const projectsJson = JSON.stringify(projects);
---

<div class="project-modal-overlay" data-visible="false" data-project-id="" data-base-url={base} data-projects={projectsJson}>
  <!-- Overlay que cierra el modal al hacer clic -->
  <div class="modal-overlay-bg"></div>

  <!-- Modal container -->
  <div class="modal-container" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <!-- Header con título y botón cerrar -->
    <div class="modal-header">
      <h2 id="modal-title" class="modal-title"></h2>
      <button class="modal-close-btn" aria-label="Cerrar modal" type="button">
        <span aria-hidden="true">✕</span>
      </button>
    </div>

    <!-- Contenido del modal -->
    <div class="modal-content">
      <!-- Media principal -->
      <div class="modal-media-section">
        <div class="modal-media-carousel"></div>
        <div class="featured-badge" style="display: none;">
          <span>⭐ Featured</span>
        </div>
      </div>

      <!-- Descripción completa -->
      <div class="modal-description-section">
        <h3>Descripción</h3>
        <p class="modal-description"></p>
      </div>

      <!-- Tecnologías -->
      <div class="modal-technologies-section">
        <h3>Tecnologías</h3>
        <div class="technologies-list"></div>
      </div>

      <!-- Categorías -->
      <div class="modal-categories-section">
        <h3>Categorías</h3>
        <div class="categories-list"></div>
      </div>
    </div>

    <!-- Footer con enlaces de acción -->
    <div class="modal-footer">
      <a href="" class="action-link github-link" target="_blank" rel="noopener noreferrer" style="display: none;">
        <span>🔗 Ver en GitHub</span>
      </a>
      <a href="" class="action-link live-link" target="_blank" rel="noopener noreferrer" style="display: none;">
        <span>🚀 Ver en Vivo</span>
      </a>
    </div>
  </div>
</div>

<style>
  /* Modal Overlay Background */
  .project-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-modal-overlay[data-visible="true"] {
    pointer-events: auto;
    opacity: 1;
  }

  .modal-overlay-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-modal-overlay[data-visible="true"] .modal-overlay-bg {
    opacity: 1;
  }

  /* Modal Container */
  .modal-container {
    position: relative;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(30, 41, 59, 0.95));
    border: 1px solid rgba(0, 255, 136, 0.2);
    border-radius: 16px;
    max-width: 800px;
    width: 90%;
    max-height: 85vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    transform: scale(0.95);
    opacity: 0;
    transition: all 0.3s ease;
  }

  .project-modal-overlay[data-visible="true"] .modal-container {
    transform: scale(1);
    opacity: 1;
  }

  /* Modal Header */
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem;
    border-bottom: 1px solid rgba(0, 255, 136, 0.1);
    background: rgba(0, 255, 136, 0.03);
  }

  .modal-title {
    margin: 0;
    font-size: 1.75rem;
    color: #fff;
    background: linear-gradient(135deg, #fff, #00ff88);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .modal-close-btn {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .modal-close-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #00ff88;
  }

  .modal-close-btn:focus {
    outline: 2px solid #00ff88;
    outline-offset: 2px;
  }

  /* Modal Content */
  .modal-content {
    flex: 1;
    padding: 2rem;
    overflow-y: auto;
  }

  .modal-media-section {
    position: relative;
    margin-bottom: 2rem;
    border-radius: 12px;
    overflow: hidden;
  }

  .modal-media-carousel {
    position: relative;
    width: 100%;
    min-height: 260px;
    background: rgba(255, 255, 255, 0.04);
  }

  .modal-media-single {
    width: 100%;
    min-height: 260px;
  }

  .modal-carousel {
    position: relative;
    width: 100%;
    min-height: 260px;
  }

  .modal-carousel-container {
    position: relative;
    width: 100%;
    min-height: 260px;
  }

  .modal-carousel-item {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .modal-carousel-item.active {
    opacity: 1;
  }

  .modal-carousel-item img,
  .modal-carousel-item video,
  .modal-media-single img,
  .modal-media-single video {
    width: 100%;
    height: 100%;
    max-height: 400px;
    object-fit: cover;
    display: block;
    border-radius: 8px;
  }

  .modal-carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.5);
    color: white;
    border: none;
    font-size: 2rem;
    padding: 0.5rem 1rem;
    cursor: pointer;
    z-index: 2;
    transition: all 0.3s ease;
    opacity: 0;
  }

  .modal-carousel:hover .modal-carousel-btn {
    opacity: 1;
  }

  .modal-carousel-btn:hover {
    background: rgba(0, 255, 136, 0.8);
    color: #0a0a14;
  }

  .modal-carousel-btn.prev {
    left: 0.5rem;
  }

  .modal-carousel-btn.next {
    right: 0.5rem;
  }

  .modal-carousel-indicators {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 2;
  }

  .modal-carousel-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid white;
    background: rgba(255, 255, 255, 0.3);
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .modal-carousel-indicator.active {
    background: #00ff88;
    border-color: #00ff88;
  }

  .modal-carousel-indicator:hover {
    background: rgba(255, 255, 255, 0.6);
  }

  .featured-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: linear-gradient(135deg, #00ff88, #00cc6f);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-weight: bold;
    color: #000;
    font-size: 0.9rem;
    box-shadow: 0 4px 12px rgba(0, 255, 136, 0.3);
  }

  .modal-description-section,
  .modal-technologies-section,
  .modal-categories-section {
    margin-bottom: 1.5rem;
  }

  .modal-description-section h3,
  .modal-technologies-section h3,
  .modal-categories-section h3 {
    color: #00ff88;
    font-size: 1.1rem;
    margin: 0 0 0.75rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .modal-description {
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin: 0;
  }

  /* Technologies List */
  .technologies-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .technology-badge {
    background: rgba(0, 255, 136, 0.1);
    color: #00ff88;
    border: 1px solid rgba(0, 255, 136, 0.3);
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* Categories List */
  .categories-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .category-badge {
    background: rgba(100, 200, 255, 0.1);
    color: #64c8ff;
    border: 1px solid rgba(100, 200, 255, 0.3);
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-transform: capitalize;
  }

  /* Modal Footer */
  .modal-footer {
    display: flex;
    gap: 1rem;
    padding: 1.5rem 2rem;
    border-top: 1px solid rgba(0, 255, 136, 0.1);
    background: rgba(0, 255, 136, 0.03);
    flex-wrap: wrap;
  }

  .action-link {
    flex: 1;
    min-width: 150px;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #00ff88, #00cc6f);
    color: #000;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    text-align: center;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    display: inline-block;
  }

  .action-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(0, 255, 136, 0.3);
  }

  .action-link:focus {
    outline: 2px solid #00ff88;
    outline-offset: 2px;
  }

  .action-link span {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  /* Scrollbar styling */
  .modal-content::-webkit-scrollbar {
    width: 8px;
  }

  .modal-content::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }

  .modal-content::-webkit-scrollbar-thumb {
    background: rgba(0, 255, 136, 0.3);
    border-radius: 4px;
  }

  .modal-content::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 255, 136, 0.5);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .modal-container {
      width: 95%;
      max-height: 90vh;
      border-radius: 12px;
    }

    .modal-header {
      padding: 1.5rem;
    }

    .modal-title {
      font-size: 1.3rem;
    }

    .modal-content {
      padding: 1.5rem;
    }

    .modal-footer {
      padding: 1rem 1.5rem;
      flex-direction: column;
    }

    .action-link {
      flex: 1;
      min-width: auto;
      width: 100%;
    }

    .modal-media-carousel,
    .modal-media-single,
    .modal-carousel,
    .modal-carousel-container {
      min-height: 220px;
    }

    .modal-carousel-item img,
    .modal-carousel-item video,
    .modal-media-single img,
    .modal-media-single video {
      max-height: 250px;
    }
  }

  @media (max-width: 480px) {
    .modal-container {
      width: 100%;
      max-height: 95vh;
      border-radius: 0;
    }

    .modal-header {
      padding: 1rem;
    }

    .modal-title {
      font-size: 1.1rem;
    }

    .modal-content {
      padding: 1rem;
    }

    .modal-footer {
      padding: 0.75rem 1rem;
    }

    .modal-description-section h3,
    .modal-technologies-section h3,
    .modal-categories-section h3 {
      font-size: 1rem;
    }
  }
</style>

<script>
  // Get modal overlay and parse projects data from attribute
  type ScriptMediaItem = {
    type: "image" | "video";
    url: string;
    alt: string;
  };

  type ScriptProject = {
    id: string;
    title: string;
    description: string;
    imageUrl: string;
    imageGallery?: string[];
    videoUrl?: string;
    videoGallery?: string[];
    technologies: string[];
    githubUrl?: string;
    liveUrl?: string;
    featured: boolean;
    categories: string[];
  };

  const overlayElement = document.querySelector<HTMLElement>(".project-modal-overlay");
  if (!overlayElement) {
    console.error("Modal overlay not found");
  } else {
    const overlay = overlayElement;
    const projectsJson = overlay.getAttribute("data-projects");
    const base = overlay.getAttribute("data-base-url") || "/";

    const projectsData: ScriptProject[] = projectsJson ? (JSON.parse(projectsJson) as ScriptProject[]) : [];
    let currentProjectId: string | null = null;

    console.log("🎯 ProjectDetailModal initialized, found", projectsData.length, "projects");

    const getImageUrl = (url: string) => {
      if (!url || url.startsWith("http")) return url;
      return url.startsWith("/") ? `${base}${url.slice(1)}` : `${base}${url}`;
    };

    const escapeHtml = (value: string) =>
      String(value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const buildMediaGallery = (project: ScriptProject) => {
      const mediaItems: ScriptMediaItem[] = [];

      if (project.imageGallery?.length) {
        mediaItems.push(
          ...project.imageGallery.map((url: string, index: number) => ({
            type: "image" as const,
            url,
            alt: `${project.title} - imagen ${index + 1}`,
          })),
        );
      } else if (project.imageUrl && !project.imageUrl.includes("placeholder")) {
        mediaItems.push({
          type: "image",
          url: project.imageUrl,
          alt: project.title,
        });
      }

      if (project.videoGallery?.length) {
        mediaItems.push(
          ...project.videoGallery.map((url: string, index: number) => ({
            type: "video" as const,
            url,
            alt: `${project.title} - video ${index + 1}`,
          })),
        );
      } else if (project.videoUrl) {
        mediaItems.push({
          type: "video" as const,
          url: project.videoUrl,
          alt: `${project.title} - video`,
        });
      }

      return mediaItems;
    };

    const renderMediaSection = (project: ScriptProject) => {
      const mediaSection = document.querySelector<HTMLElement>(".modal-media-carousel");
      if (!mediaSection) return;

      const mediaItems = buildMediaGallery(project);
      if (!mediaItems.length) {
        mediaSection.innerHTML = "";
        return;
      }

      if (mediaItems.length === 1) {
        mediaSection.innerHTML = `
          <div class="modal-media-single">
            ${
              mediaItems[0].type === "video"
                ? `<video src="${getImageUrl(mediaItems[0].url)}" muted autoplay loop playsinline controls preload="metadata"></video>`
                : `<img src="${getImageUrl(mediaItems[0].url)}" alt="${escapeHtml(mediaItems[0].alt)}" />`
            }
          </div>
        `;
        return;
      }

      mediaSection.innerHTML = `
        <div class="modal-carousel">
          <div class="modal-carousel-container">
            ${mediaItems
              .map(
                (media: ScriptMediaItem, index: number) => `
                  <div class="modal-carousel-item ${index === 0 ? "active" : ""}" data-index="${index}">
                    ${
                      media.type === "video"
                        ? `<video src="${getImageUrl(media.url)}" muted autoplay loop playsinline controls preload="metadata"></video>`
                        : `<img src="${getImageUrl(media.url)}" alt="${escapeHtml(media.alt)}" />`
                    }
                  </div>
                `,
              )
              .join("")}
          </div>
          <button class="modal-carousel-btn prev" data-carousel="prev">‹</button>
          <button class="modal-carousel-btn next" data-carousel="next">›</button>
          <div class="modal-carousel-indicators">
            ${mediaItems
              .map(
                (_, index) =>
                  `<button class="modal-carousel-indicator ${index === 0 ? "active" : ""}" data-index="${index}"></button>`,
              )
              .join("")}
          </div>
        </div>
      `;

      const carousel = mediaSection.querySelector<HTMLElement>(".modal-carousel");
      if (!carousel) return;

      const items = carousel.querySelectorAll<HTMLElement>(".modal-carousel-item");
      const indicators = carousel.querySelectorAll<HTMLElement>(".modal-carousel-indicator");
      const prevBtn = carousel.querySelector<HTMLButtonElement>('[data-carousel="prev"]');
      const nextBtn = carousel.querySelector<HTMLButtonElement>('[data-carousel="next"]');

      let currentIndex: number = 0;

      const showItem = (index: number) => {
        items.forEach((item: HTMLElement, itemIndex: number) => {
          item.classList.toggle("active", itemIndex === index);

          const video = item.querySelector<HTMLVideoElement>("video");
          if (video instanceof HTMLVideoElement) {
            if (itemIndex === index) {
              video.currentTime = 0;
              video.play().catch(() => {});
            } else {
              video.pause();
            }
          }
        });

        indicators.forEach((indicator: HTMLElement, itemIndex: number) => {
          indicator.classList.toggle("active", itemIndex === index);
        });

        currentIndex = index;
      };

      prevBtn?.addEventListener("click", (event: MouseEvent) => {
        event.preventDefault();
        event.stopPropagation();
        const newIndex = currentIndex === 0 ? items.length - 1 : currentIndex - 1;
        showItem(newIndex);
      });

      nextBtn?.addEventListener("click", (event: MouseEvent) => {
        event.preventDefault();
        event.stopPropagation();
        const newIndex = currentIndex === items.length - 1 ? 0 : currentIndex + 1;
        showItem(newIndex);
      });

      indicators.forEach((indicator: HTMLElement, index: number) => {
        indicator.addEventListener("click", (event: MouseEvent) => {
          event.preventDefault();
          event.stopPropagation();
          showItem(index);
        });
      });
    };

    function updateModalContent(projectId: string) {
      const project = projectsData.find((p: ScriptProject) => p.id === projectId);
      if (!project) return;

      currentProjectId = projectId;
      overlay.setAttribute("data-visible", "true");
      overlay.setAttribute("data-project-id", projectId);

      // Update title
      const titleEl = document.querySelector<HTMLElement>(".modal-title");
      if (titleEl) titleEl.textContent = project.title;

      // Update description
      const descEl = document.querySelector<HTMLElement>(".modal-description");
      if (descEl) descEl.textContent = project.description;

      // Update media
      renderMediaSection(project);

      // Update featured badge
      const featuredBadge = document.querySelector<HTMLElement>(".featured-badge");
      if (featuredBadge) {
        featuredBadge.style.display = project.featured ? "block" : "none";
      }

      // Update technologies
      const techList = document.querySelector<HTMLElement>(".technologies-list");
      if (techList) {
        techList.innerHTML = project.technologies
          .map((tech: string) => `<div class="technology-badge">${tech}</div>`)
          .join("");
      }

      // Update categories
      const catList = document.querySelector<HTMLElement>(".categories-list");
      if (catList) {
        catList.innerHTML = project.categories
          .map((cat: string) => `<div class="category-badge">${cat}</div>`)
          .join("");
      }

      // Update links
      const githubLink = document.querySelector<HTMLAnchorElement>(".github-link");
      if (githubLink) {
        if (project.githubUrl) {
          githubLink.href = project.githubUrl;
          githubLink.style.display = "block";
        } else {
          githubLink.style.display = "none";
        }
      }

      const liveLink = document.querySelector<HTMLAnchorElement>(".live-link");
      if (liveLink) {
        if (project.liveUrl) {
          liveLink.href = project.liveUrl;
          liveLink.style.display = "block";
        } else {
          liveLink.style.display = "none";
        }
      }
    }

    function close() {
      overlay.setAttribute("data-visible", "false");
      overlay.setAttribute("data-project-id", "");
      currentProjectId = null;
    }

    function initializeEventListeners() {
      console.log("🎯 Modal event listeners initializing...");

      // Listen for custom open event
      document.addEventListener("project-modal:open", (e: Event) => {
        const detail = (e as CustomEvent<{ projectId?: string }>).detail;
        console.log("📢 project-modal:open event received!", detail);
        const projectId = detail?.projectId;
        if (projectId) {
          updateModalContent(projectId);
        }
      });

      // Close button
      const closeBtn = document.querySelector<HTMLButtonElement>(".modal-close-btn");
      if (closeBtn) {
        closeBtn.addEventListener("click", close);
      }

      // Overlay click
      const overlayBg = document.querySelector<HTMLElement>(".modal-overlay-bg");
      if (overlayBg) {
        overlayBg.addEventListener("click", close);
      }

      // Escape key
      document.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Escape" && currentProjectId) {
          close();
        }
      });
    }

    // Initialize when ready
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initializeEventListeners);
    } else {
      initializeEventListeners();
    }
  }
</script>
